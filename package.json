{
  "name": "vidly-project",
  "version": "2.1.0",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "description": "RESTful API for movie rental service with comprehensive security and best practices",
  "main": "api/index.js",
  "scripts": {
    "start": "node --no-deprecation api/index.js",
    "test": "jest --watchAll --verbose --detectOpenHandles --coverage",
    "test:ci": "jest --ci --coverage --runInBand --forceExit",
    "dev": "export NODE_ENV=development&& nodemon --no-deprecation",
    "prod": "export NODE_ENV=production&& node --no-deprecation api/index.js",
    "debug": "export DEBUG=Log& node --no-deprecation api/index.js"
  },
  "keywords": [
    "api",
    "rest",
    "express",
    "mongodb",
    "jwt",
    "security"
  ],
  "author": "Rei Orozco",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "debug": "^4.3.3",
    "dotenv": "^12.0.3",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.2.0",
    "joi": "^17.5.0",
    "joi-objectid": "^4.0.2",
    "jsonwebtoken": "9.0.3",
    "lodash": "^4.17.21",
    "luxon": "2.5.2",
    "mongoose": "^9.7.3",
    "morgan": "^1.11.0",
    "pug": "^3.0.4",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-mongodb": "^5.0.7"
  },
  "devDependencies": {
    "eslint": "^8.9.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.1.14",
    "prettier": "^2.5.1",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "./tests/setup.js",
    "globalTeardown": "./tests/teardown.js",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ],
    "testTimeout": 10000
  }
}
